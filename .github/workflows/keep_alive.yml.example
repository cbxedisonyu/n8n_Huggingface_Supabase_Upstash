name: Supabase Keep Alive

on:
  schedule:
    # 手動取消以下註解並設定時間（例如 '0 */8 * * *'）
    # - cron: '<YOUR_CRON_SCHEDULE>'
  workflow_dispatch: # 保留手動按鈕，方便測試
  
jobs:
  ping_supabase:
    runs-on: ubuntu-latest
    steps:
      - name: Ping Supabase API
        run: |
          curl -f -s -o /dev/null -w "Status Code: %{http_code}\n" \
          -X GET "${{ secrets.SUPABASE_URL }}/rest/v1/health_check?select=*&limit=1" \
          -H "apikey: ${{ secrets.SUPABASE_ANON_KEY }}" \
          -H "Authorization: Bearer ${{ secrets.SUPABASE_ANON_KEY }}"
